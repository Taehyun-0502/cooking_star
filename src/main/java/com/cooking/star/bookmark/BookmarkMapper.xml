<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.cooking.star.bookmark.BookmarkMapper">
  
  <insert id="addBookmark" parameterType="BookmarkDTO" >
  INSERT INTO "MYRECIPE_BOOKMARK" ("USERNAME","RECIPE_NUM")
  VALUES(#{username},#{recipeNum})
  
  </insert>
  <select id="bookmarkCount" parameterType="BookmarkDTO" resultType="int">
  SELECT COUNT(*) FROM "MYRECIPE_BOOKMARK"
  WHERE "USERNAME"=#{username}
  </select>
  
  <select id="list" parameterType="BookmarkDTO" resultType="BookmarkDTO">
  SELECT * FROM "MYRECIPE_BOOKMARK"
  WHERE "USERNAME"=#{username}
  </select>
  
  <select id="bookmarkCheck" parameterType="BookmarkDTO" resultType="int">
  SELECT COUNT(*) FROM "MYRECIPE_BOOKMARK"
  WHERE "USERNAME"=#{username}
  AND "RECIPE_NUM"=#{recipeNum}
  </select>
  
  <delete id="deleteBookmark" parameterType="BookmarkDTO">
  DELETE FROM "MYRECIPE_BOOKMARK"
  WHERE "USERNAME"=#{username}
  AND "RECIPE_NUM"=#{recipeNum}
  </delete>
  
  
  
  
  
  
  
  </mapper>
