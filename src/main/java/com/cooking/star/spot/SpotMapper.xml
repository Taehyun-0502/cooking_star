<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cooking.star.spot.SpotMapper">

<insert id="add" parameterType="SpotDTO" >

INSERT INTO "MY_SPOT"
VALUES (default,#{username},#{placeName},#{addressName},#{placeUrl},#{phone})


</insert>

<select id="myList" parameterType="String" resultType="SpotDTO">
SELECT * FROM "MY_SPOT"
WHERE "USERNAME"=#{username}

</select>


<delete id="delete" parameterType="SpotDTO">
DELETE FROM "MY_SPOT"
WHERE "USERNAME"=#{username}
AND "SPOT_NUM"=#{spotNum}



</delete>

















</mapper>